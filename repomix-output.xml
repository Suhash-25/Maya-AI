/* GLOBAL RESET */
* {
  box-sizing: border-box;
}

#root, body, html {
  height: 100vh;
  width: 100vw;
  margin: 0;
  padding: 0;
  background-color: #131314;
  overflow: hidden; /* Prevents double scrollbars */
}

/* MAIN CONTAINER */
.app-container {
  display: flex;
  height: 100vh;
  width: 100vw;
  position: relative;
  color: #e3e3e3;
  font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

/* AURORA BACKGROUND */
.aurora-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.blob {
  position: absolute;
  width: 70vw;
  height: 70vh;
  filter: blur(120px);
  opacity: 0.2;
  border-radius: 50%;
}

.blob-blue { background: #4285f4; top: -20%; left: -10%; }
.blob-purple { background: #9333ea; bottom: -20%; right: -10%; }

/* SIDEBAR */
.sidebar {
  width: 280px;
  background-color: #1e1f20;
  display: flex;
  flex-direction: column;
  padding: 16px;
  z-index: 20;
}

.new-chat-btn {
  background: #1a1a1c;
  border: 1px solid #3c4043;
  color: white;
  padding: 14px;
  border-radius: 50px;
  cursor: pointer;
  margin-bottom: 20px;
  font-weight: 500;
}

/* MAIN CONTENT AREA */
.main-chat {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 10;
  height: 100vh;
}

.header {
  padding: 20px 40px;
  font-size: 1.2rem;
  font-weight: 500;
  color: #8e918f;
}

.chat-window {
  flex: 1;
  width: 100%;
  max-width: 850px;
  margin: 0 auto;
  overflow-y: auto;
  padding: 20px;
  display: flex;
  flex-direction: column;
}

.welcome-screen {
  margin-top: 15vh;
  text-align: left;
}

.welcome-screen h1 {
  font-size: 3.5rem;
  background: linear-gradient(90deg, #4285f4, #d96570);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: 500;
}

/* INPUT PILL */
.input-area {
  width: 100%;
  max-width: 850px;
  margin: 0 auto;
  padding: 20px 20px 40px 20px;
}

.input-pill {
  background-color: #1e1f20;
  border: 1px solid #3c4043;
  border-radius: 100px;
  display: flex;
  align-items: center;
  padding: 12px 24px;
  gap: 15px;
  transition: border 0.2s;
}

.input-pill:focus-within {
  border-color: #5f6368;
}

.input-pill input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: white;
  font-size: 1.1rem;
}

/* MESSAGES */
.message { margin-bottom: 30px; display: flex; }
.user-msg { justify-content: flex-end; }
.bubble { max-width: 80%; padding: 15px; border-radius: 20px; line-height: 1.5; }
.user-bubble { background: #2b2c2f; }
.maya-bubble { background: transparent; font-size: 1.1rem; }

.shimmer-line {
  height: 12px;
  background: linear-gradient(90deg, #3c4043 25%, #4f5256 50%, #3c4043 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 6px;
  margin-bottom: 8px;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.sound-wave {
  display: flex;
  gap: 4px;
  align-items: center;
  padding: 10px 20px;
}

.wave-bar {
  width: 4px;
  background-color: #4285f4;
  border-radius: 2px;
}

.active-mic {
  color: #ea4335 !important;
  text-shadow: 0 0 10px rgba(234, 67, 53, 0.5);
}

.vibe-tag {
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-top: 10px;
  color: #4285f4;
  font-weight: bold;
}

.steps-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.step-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.85rem;
  color: #a0a0a0;
}

.step-icon {
  font-size: 1rem;
}

.typing-dots {
  display: flex;
  gap: 4px;
  padding: 5px 0;
}

.typing-dots span {
  width: 6px;
  height: 6px;
  background: #4285f4;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.typing-dots span:nth-child(1) { animation-delay: -0.32s; }
.typing-dots span:nth-child(2) { animation-delay: -0.16s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1.0); }
}

.thinking-state {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(66, 133, 244, 0.2);
  padding: 15px;
}

.steps-container {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.step-row {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 0.9rem;
  color: #bdc1c6;
}

.step-icon {
  font-size: 1.1rem;
}

.gemini-shimmer {
  margin-top: 15px;
  height: 4px;
  width: 100%;
  background: linear-gradient(90deg, #4285f4, #9b72cb, #d96570, #4285f4);
  background-size: 200% 100%;
  animation: shimmerMove 2s infinite linear;
  border-radius: 2px;
}

@keyframes shimmerMove {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

.file-preview-tag {
  background: rgba(45, 90, 240, 0.2);
  border: 1px solid var(--nebula-accent);
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 0.75rem;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-right: 10px;
}

.file-preview-tag button {
  background: none;
  border: none;
  color: #fff;
  cursor: pointer;
  font-weight: bold;
}

.utility-icon.active-file {
  color: var(--nebula-accent);
  filter: drop-shadow(0 0 5px var(--nebula-accent));
}

.input-pill-inner {
  display: flex;
  align-items: center;
  flex: 1;
}

.chat-inline-image {
  max-width: 100%;
  max-height: 250px;
  border-radius: 12px;
  margin-bottom: 10px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  display: block;
}

.chat-image-container {
  width: 100%;
  display: flex;
  justify-content: flex-start;
}

.user-msg .chat-image-container {
  justify-content: flex-end;
}

.chat-inline-image {
  max-width: 100%;
  max-height: 300px;
  border-radius: 12px;
  margin-bottom: 12px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  display: block;
}

.chat-image-container {
  width: 100%;
  display: flex;
  margin-top: 4px;
}

.user-msg .chat-image-container {
  justify-content: flex-end;
}

/* LIGHTBOX STYLES */
.lightbox-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.9);
  -webkit-backdrop-filter: blur(10px);
  backdrop-filter: blur(10px);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
