}

.lightbox-close:hover {
  opacity: 1;
}

/* Make images look clickable */
.chat-inline-image.clickable {
  cursor: zoom-in;
  transition: transform 0.2s ease, filter 0.2s ease;
}

.chat-inline-image.clickable:hover {
  filter: brightness(1.1);
  transform: scale(1.02);
}
